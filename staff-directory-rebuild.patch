+
+from django.contrib.auth.models import User
 from django.test import TestCase
+from django.urls import reverse
+
+from .models import Department, Employee, EmployeeHistory, EmployeeStatus, ExitRecord, Position, Role
+
+
+class StaffDirectoryTests(TestCase):
+    def setUp(self):
+        self.admin = User.objects.create_user("admin", password="pass", is_staff=True)
+        self.regular = User.objects.create_user("regular", password="pass")
+        self.department = Department.objects.create(name="HR")
+        self.position = Position.objects.create(title="Manager", grade_level=1, base_salary=1000)
+        self.role = Role.objects.create(name="HR Manager")
+        self.active = EmployeeStatus.objects.create(name="Active")
+        self.terminated = EmployeeStatus.objects.create(name="Terminated")
+        self.client.force_login(self.admin)
+
+    def post_json(self, name, payload, args=None):
+        return self.client.post(
+            reverse(name, args=args or []),
+            data=json.dumps(payload),
+            content_type="application/json",
+        )
+
+    def employee_payload(self, **changes):
+        payload = {
+            "first_name": "Ada",
+            "last_name": "Lovelace",
+            "username": "ada",
+            "email": "ada@example.com",
+            "employee_id": "EMP-001",
+            "department_id": self.department.pk,
+            "position_id": self.position.pk,
+            "role_id": self.role.pk,
+            "status_id": self.active.pk,
+            "hire_date": "2026-06-07",
+            "phone": "123",
+            "address": "Office",
+        }
+        payload.update(changes)
+        return payload
+
+    def create_employee(self):
+        response = self.post_json("api_employee_create", self.employee_payload())
+        self.assertEqual(response.status_code, 201)
+        return Employee.objects.get(employee_id="EMP-001"), response.json()["data"]
+
+    def test_staff_access_is_required(self):
+        response = self.client.get(reverse("staff_directory"))
+        self.assertEqual(response.status_code, 200)
+        self.assertContains(response, "Create Employee")
+        self.client.force_login(self.regular)
+        self.assertEqual(self.client.get(reverse("staff_directory")).status_code, 403)
+        self.assertEqual(self.client.get(reverse("api_employees")).status_code, 403)
+        self.client.logout()
+        self.assertEqual(self.client.get(reverse("api_employees")).status_code, 401)
+
+    def test_create_employee_creates_login_profile_history_and_password(self):
+        employee, data = self.create_employee()
+        self.assertEqual(employee.user.email, "ada@example.com")
+        self.assertEqual(employee.status, self.active)
+        self.assertTrue(employee.user.check_password(data["temporary_password"]))
+        self.assertTrue(EmployeeHistory.objects.filter(employee=employee, event_type="hired").exists())
+
+    def test_create_rejects_duplicate_username_email_and_employee_id(self):
+        self.create_employee()
+        for changes in [
+            {"employee_id": "EMP-002", "email": "other@example.com"},
+            {"employee_id": "EMP-002", "username": "other"},
+            {"username": "other", "email": "other@example.com"},
+        ]:
+            response = self.post_json("api_employee_create", self.employee_payload(**changes))
+            self.assertEqual(response.status_code, 400)
+
+    def test_update_changes_core_fields_only(self):
+        employee, _ = self.create_employee()
+        employee.attendance_pin = "123456"
+        employee.save(update_fields=["attendance_pin"])
+        response = self.post_json(
+            "api_employee_update",
+            self.employee_payload(first_name="Grace", username="grace", email="grace@example.com"),
+            [employee.pk],
+        )
+        self.assertEqual(response.status_code, 200)
+        employee.refresh_from_db()
+        self.assertEqual(employee.first_name, "Grace")
+        self.assertEqual(employee.user.username, "grace")
+        self.assertEqual(employee.attendance_pin, "123456")
+
+    def test_terminate_and_activate_employee(self):
+        employee, _ = self.create_employee()
+        response = self.post_json(
+            "api_employee_status_change",
+            {"action": "terminate", "exit_date": "2026-06-07", "reason": "Contract ended"},
+            [employee.pk],
+        )
+        self.assertEqual(response.status_code, 200)
+        employee.refresh_from_db()
+        employee.user.refresh_from_db()
+        self.assertEqual(employee.status, self.terminated)
+        self.assertFalse(employee.user.is_active)
+        self.assertTrue(ExitRecord.objects.filter(employee=employee, reason="Contract ended").exists())
+        self.assertTrue(EmployeeHistory.objects.filter(employee=employee, event_type="terminated").exists())
+
+        response = self.post_json("api_employee_status_change", {"action": "activate"}, [employee.pk])
+        self.assertEqual(response.status_code, 200)
+        employee.refresh_from_db()
+        employee.user.refresh_from_db()
+        self.assertEqual(employee.status, self.active)
+        self.assertTrue(employee.user.is_active)
+        self.assertTrue(EmployeeHistory.objects.filter(employee=employee, event_type="reinstated").exists())
 
