diff --git a/hr/templates/hr/staff_directory.html b/hr/templates/hr/staff_directory.html
new file mode 100644
index 0000000..c0419bc
--- /dev/null
+++ b/hr/templates/hr/staff_directory.html
@@ -0,0 +1,161 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>Staff Directory</title>
+  <style>
+    :root { color-scheme: light; font-family: Arial, sans-serif; color: #172033; background: #f4f6fa; }
+    * { box-sizing: border-box; }
+    body { margin: 0; }
+    header { display: flex; justify-content: space-between; align-items: center; padding: 22px 32px; background: #fff; border-bottom: 1px solid #dfe4ed; }
+    main { padding: 28px 32px; }
+    button { border: 0; border-radius: 7px; padding: 9px 13px; cursor: pointer; font-weight: 600; }
+    .primary { background: #2457d6; color: white; }
+    .secondary { background: #e8edf8; color: #24395f; }
+    .danger { background: #b42318; color: white; }
+    .success { background: #16784a; color: white; }
+    .card { background: white; border: 1px solid #dfe4ed; border-radius: 10px; overflow: hidden; }
+    table { width: 100%; border-collapse: collapse; }
+    th, td { padding: 13px; border-bottom: 1px solid #edf0f5; text-align: left; }
+    th { background: #f8f9fc; font-size: 13px; }
+    td { font-size: 14px; }
+    .actions { display: flex; gap: 7px; flex-wrap: wrap; }
+    .status { display: inline-block; padding: 4px 8px; border-radius: 999px; background: #edf1f7; }
+    dialog { width: min(720px, calc(100% - 30px)); border: 0; border-radius: 12px; padding: 0; box-shadow: 0 20px 70px #18223b55; }
+    dialog::backdrop { background: #17203388; }
+    form { padding: 24px; }
+    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 15px; }
+    label { display: grid; gap: 6px; font-size: 13px; font-weight: 600; }
+    input, select, textarea { width: 100%; padding: 10px; border: 1px solid #cdd5e2; border-radius: 7px; font: inherit; }
+    textarea { min-height: 75px; resize: vertical; }
+    .wide { grid-column: 1 / -1; }
+    .dialog-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px; }
+    #message { margin-bottom: 16px; padding: 11px; border-radius: 7px; display: none; white-space: pre-wrap; }
+    #message.ok { display: block; background: #e8f7ef; color: #145c3b; }
+    #message.error { display: block; background: #fdeceb; color: #8f1d16; }
+    @media (max-width: 800px) { .grid { grid-template-columns: 1fr; } .wide { grid-column: auto; } main, header { padding: 18px; } }
+  </style>
+</head>
+<body>
+  <header>
+    <div><strong>Staff Directory</strong><div style="color:#667085;font-size:13px">Create and manage employees</div></div>
+    {% if not access_denied %}<button class="primary" id="createButton">Create Employee</button>{% endif %}
+  </header>
+  <main>
+    {% if access_denied %}
+      <div class="card" style="padding:24px">Staff or administrator access is required.</div>
+    {% else %}
+      <div id="message"></div>
+      <div class="card">
+        <table>
+          <thead><tr><th>Employee</th><th>ID</th><th>Department</th><th>Position</th><th>Status</th><th>Actions</th></tr></thead>
+          <tbody id="employeeRows"><tr><td colspan="6">Loading...</td></tr></tbody>
+        </table>
+      </div>
+    {% endif %}
+  </main>
+
+  {% if not access_denied %}
+  <dialog id="employeeDialog">
+    <form id="employeeForm">
+      <h2 id="formTitle">Create Employee</h2>
+      <input type="hidden" id="recordId">
+      <div class="grid">
+        <label>First name<input id="first_name" required></label>
+        <label>Last name<input id="last_name" required></label>
+        <label>Username<input id="username" required></label>
+        <label>Email<input id="email" type="email" required></label>
+        <label>Employee ID<input id="employee_id" required></label>
+        <label>Hire date<input id="hire_date" type="date"></label>
+        <label>Department<select id="department_id"></select></label>
+        <label>Position<select id="position_id"></select></label>
+        <label>Role<select id="role_id"></select></label>
+        <label>Status<select id="status_id"></select></label>
+        <label class="wide">Phone<input id="phone"></label>
+        <label class="wide">Address<textarea id="address"></textarea></label>
+      </div>
+      <div class="dialog-actions"><button type="button" class="secondary" data-close>Cancel</button><button class="primary" type="submit">Save</button></div>
+    </form>
+  </dialog>
+
+  <dialog id="terminateDialog">
+    <form id="terminateForm">
+      <h2>Terminate Employee</h2>
+      <input type="hidden" id="terminateId">
+      <label>Exit date<input id="exit_date" type="date" required></label><br>
+      <label>Reason<textarea id="reason" required></textarea></label>
+      <div class="dialog-actions"><button type="button" class="secondary" data-close>Cancel</button><button class="danger" type="submit">Terminate</button></div>
+    </form>
+  </dialog>
+
+  <script>
+    const csrf = "{{ csrf_token }}";
+    const state = { employees: [], refs: {} };
+    const employeeDialog = document.querySelector("#employeeDialog");
+    const terminateDialog = document.querySelector("#terminateDialog");
+    const fields = ["first_name","last_name","username","email","employee_id","hire_date","department_id","position_id","role_id","status_id","phone","address"];
+
+    async function api(url, options = {}) {
+      options.headers = {"Content-Type":"application/json","X-CSRFToken":csrf,...options.headers};
+      const response = await fetch(url, options);
+      const body = await response.json();
+      if (!response.ok || !body.success) throw new Error(body.error + (body.data ? "\n" + JSON.stringify(body.data) : ""));
+      return body.data;
+    }
+    function message(text, type = "ok") {
+      const box = document.querySelector("#message"); box.textContent = text; box.className = type;
+    }
+    function optionList(items, label) {
+      return `<option value="">Not selected</option>` + items.map(item => `<option value="${item.id}">${item[label]}</option>`).join("");
+    }
+    async function load() {
+      try {
+        [state.employees, state.refs] = await Promise.all([api("/api/employees/"), api("/api/reference-data/")]);
+        department_id.innerHTML = optionList(state.refs.departments, "name");
+        position_id.innerHTML = optionList(state.refs.positions, "title");
+        role_id.innerHTML = optionList(state.refs.roles, "name");
+        status_id.innerHTML = optionList(state.refs.statuses, "name");
+        employeeRows.innerHTML = state.employees.length ? state.employees.map(e => `<tr>
+          <td><strong>${e.full_name}</strong><br><small>${e.email || e.username}</small></td><td>${e.employee_id}</td>
+          <td>${e.department || "-"}</td><td>${e.position || "-"}</td><td><span class="status">${e.status || "-"}</span></td>
+          <td><div class="actions"><button class="secondary" onclick="editEmployee(${e.id})">Edit</button>
+          ${e.status.toLowerCase() === "terminated" ? `<button class="success" onclick="activate(${e.id})">Activate</button>` : `<button class="danger" onclick="openTerminate(${e.id})">Terminate</button>`}</div></td>
+        </tr>`).join("") : `<tr><td colspan="6">No employees found.</td></tr>`;
+      } catch (error) { message(error.message, "error"); }
+    }
+    function openCreate() {
+      employeeForm.reset(); recordId.value = ""; formTitle.textContent = "Create Employee";
+      hire_date.value = new Date().toISOString().slice(0,10); employeeDialog.showModal();
+    }
+    function editEmployee(id) {
+      const employee = state.employees.find(e => e.id === id); recordId.value = id; formTitle.textContent = "Edit Employee";
+      fields.forEach(field => document.querySelector("#" + field).value = employee[field] ?? ""); employeeDialog.showModal();
+    }
+    function openTerminate(id) { terminateForm.reset(); terminateId.value = id; exit_date.value = new Date().toISOString().slice(0,10); terminateDialog.showModal(); }
+    async function activate(id) {
+      if (!confirm("Activate this employee and re-enable their login?")) return;
+      try { await api(`/api/employees/status/${id}/`, {method:"POST",body:JSON.stringify({action:"activate"})}); message("Employee activated."); await load(); }
+      catch (error) { message(error.message, "error"); }
+    }
+    createButton.addEventListener("click", openCreate);
+    document.querySelectorAll("[data-close]").forEach(button => button.addEventListener("click", () => button.closest("dialog").close()));
+    employeeForm.addEventListener("submit", async event => {
+      event.preventDefault(); const payload = {}; fields.forEach(field => payload[field] = document.querySelector("#" + field).value);
+      const id = recordId.value; const url = id ? `/api/employees/update/${id}/` : "/api/employees/create/";
+      try {
+        const result = await api(url, {method:"POST",body:JSON.stringify(payload)}); employeeDialog.close();
+        message(result.temporary_password ? `Employee created.\nTemporary password: ${result.temporary_password}` : "Employee updated.");
+        await load();
+      } catch (error) { message(error.message, "error"); }
+    });
+    terminateForm.addEventListener("submit", async event => {
+      event.preventDefault();
+      try { await api(`/api/employees/status/${terminateId.value}/`, {method:"POST",body:JSON.stringify({action:"terminate",exit_date:exit_date.value,reason:reason.value})}); terminateDialog.close(); message("Employee terminated."); await load(); }
+      catch (error) { message(error.message, "error"); }
+    });
+    load();
+  </script>
+  {% endif %}
+</body>
+</html>
