diff --git a/hr/views.py b/hr/views.py
index e69de29..e99e8e1 100644
--- a/hr/views.py
+++ b/hr/views.py
@@ -0,0 +1,343 @@
+import json
+from functools import wraps
+
+from django.contrib.auth.models import User
+from django.contrib.auth.password_validation import validate_password
+from django.core.exceptions import ValidationError
+from django.core.validators import validate_email
+from django.db import IntegrityError, transaction
+from django.http import JsonResponse
+from django.shortcuts import render
+from django.utils import timezone
+from django.utils.crypto import get_random_string
+from django.views.decorators.http import require_GET, require_POST
+
+from .models import (
+    Department,
+    Employee,
+    EmployeeHistory,
+    EmployeeStatus,
+    ExitRecord,
+    Position,
+    Role,
+)
+
+
+def _ok(data=None, status=200):
+    return JsonResponse({"success": True, "data": data, "error": None}, status=status)
+
+
+def _error(message, status=400, details=None):
+    return JsonResponse(
+        {"success": False, "data": details, "error": message},
+        status=status,
+    )
+
+
+def _staff_required(view):
+    @wraps(view)
+    def wrapped(request, *args, **kwargs):
+        if not request.user.is_authenticated:
+            return _error("Authentication required.", status=401)
+        if not (request.user.is_staff or request.user.is_superuser):
+            return _error("Staff access required.", status=403)
+        return view(request, *args, **kwargs)
+
+    return wrapped
+
+
+def _read_json(request):
+    try:
+        return json.loads(request.body or "{}")
+    except json.JSONDecodeError:
+        raise ValidationError("Request body must contain valid JSON.")
+
+
+def _clean_text(data, key, required=False):
+    value = str(data.get(key, "") or "").strip()
+    if required and not value:
+        raise ValidationError({key: "This field is required."})
+    return value
+
+
+def _parse_date(value, field_name, required=False):
+    value = str(value or "").strip()
+    if not value:
+        if required:
+            raise ValidationError({field_name: "This field is required."})
+        return None
+    try:
+        return timezone.datetime.strptime(value, "%Y-%m-%d").date()
+    except ValueError:
+        raise ValidationError({field_name: "Use YYYY-MM-DD format."})
+
+
+def _resolve_optional(model, value, field_name):
+    if value in (None, ""):
+        return None
+    try:
+        return model.objects.get(pk=value)
+    except (model.DoesNotExist, ValueError, TypeError):
+        raise ValidationError({field_name: "Invalid selection."})
+
+
+def _validation_details(exc):
+    if hasattr(exc, "message_dict"):
+        return exc.message_dict
+    return {"non_field_errors": exc.messages}
+
+
+def _recorded_by(request):
+    return Employee.objects.filter(user=request.user).first()
+
+
+def _status_named(name):
+    status = EmployeeStatus.objects.filter(name__iexact=name).first()
+    return status or EmployeeStatus.objects.create(name=name)
+
+
+def _employee_or_none(employee_id):
+    return Employee.objects.select_related("user", "status").filter(pk=employee_id).first()
+
+
+def _employee_data(employee):
+    user = employee.user
+    return {
+        "id": employee.pk,
+        "first_name": employee.first_name,
+        "last_name": employee.last_name,
+        "full_name": employee.get_full_name(),
+        "username": user.username if user else "",
+        "email": user.email if user else "",
+        "employee_id": employee.employee_id or "",
+        "department_id": employee.department_id,
+        "department": employee.department.name if employee.department else "",
+        "position_id": employee.position_id,
+        "position": employee.position.title if employee.position else "",
+        "role_id": employee.role_id,
+        "role": employee.role.name if employee.role else "",
+        "status_id": employee.status_id,
+        "status": employee.status.name if employee.status else "",
+        "hire_date": employee.hire_date.isoformat() if employee.hire_date else "",
+        "phone": employee.phone,
+        "address": employee.address,
+        "login_active": bool(user and user.is_active),
+    }
+
+
+def _validate_unique_user(username, email, user=None):
+    usernames = User.objects.filter(username__iexact=username)
+    emails = User.objects.filter(email__iexact=email)
+    if user:
+        usernames = usernames.exclude(pk=user.pk)
+        emails = emails.exclude(pk=user.pk)
+    errors = {}
+    if usernames.exists():
+        errors["username"] = "This username is already in use."
+    if emails.exists():
+        errors["email"] = "This email is already in use."
+    if errors:
+        raise ValidationError(errors)
+
+
+def _validate_employee_id(employee_id, employee=None):
+    matches = Employee.all_objects.filter(employee_id__iexact=employee_id)
+    if employee:
+        matches = matches.exclude(pk=employee.pk)
+    if matches.exists():
+        raise ValidationError({"employee_id": "This employee ID is already in use."})
+
+
+def _employee_values(data):
+    return {
+        "first_name": _clean_text(data, "first_name", required=True),
+        "last_name": _clean_text(data, "last_name", required=True),
+        "employee_id": _clean_text(data, "employee_id", required=True),
+        "department": _resolve_optional(Department, data.get("department_id"), "department_id"),
+        "position": _resolve_optional(Position, data.get("position_id"), "position_id"),
+        "role": _resolve_optional(Role, data.get("role_id"), "role_id"),
+        "status": _resolve_optional(EmployeeStatus, data.get("status_id"), "status_id"),
+        "hire_date": _parse_date(data.get("hire_date"), "hire_date") or timezone.localdate(),
+        "phone": _clean_text(data, "phone"),
+        "address": _clean_text(data, "address"),
+    }
+
+
+def staff_directory(request):
+    if not request.user.is_authenticated:
+        from django.contrib.auth.views import redirect_to_login
+
+        return redirect_to_login(request.get_full_path())
+    if not (request.user.is_staff or request.user.is_superuser):
+        return render(request, "hr/staff_directory.html", {"access_denied": True}, status=403)
+    return render(request, "hr/staff_directory.html")
+
+
+@require_GET
+@_staff_required
+def api_employees(request):
+    employees = Employee.objects.select_related(
+        "user", "department", "position", "role", "status"
+    ).order_by("first_name", "last_name", "pk")
+    return _ok([_employee_data(employee) for employee in employees])
+
+
+@require_GET
+@_staff_required
+def api_reference_data(request):
+    return _ok(
+        {
+            "departments": list(Department.objects.order_by("name").values("id", "name")),
+            "positions": list(Position.objects.order_by("title").values("id", "title")),
+            "roles": list(Role.objects.order_by("name").values("id", "name")),
+            "statuses": list(EmployeeStatus.objects.order_by("name").values("id", "name")),
+        }
+    )
+
+
+@require_POST
+@_staff_required
+def create_employee(request):
+    try:
+        data = _read_json(request)
+        username = _clean_text(data, "username", required=True)
+        email = _clean_text(data, "email", required=True)
+        validate_email(email)
+        values = _employee_values(data)
+        _validate_unique_user(username, email)
+        _validate_employee_id(values["employee_id"])
+        active_status = _status_named("Active")
+        values["status"] = values["status"] or active_status
+        temporary_password = get_random_string(14)
+        validate_password(temporary_password)
+
+        with transaction.atomic():
+            user = User.objects.create_user(
+                username=username,
+                email=email,
+                password=temporary_password,
+                first_name=values["first_name"],
+                last_name=values["last_name"],
+            )
+            employee, _ = Employee.objects.get_or_create(user=user)
+            for field, value in values.items():
+                setattr(employee, field, value)
+            employee.save()
+            EmployeeHistory.objects.create(
+                employee=employee,
+                department=employee.department,
+                position=employee.position,
+                event_type="hired",
+                new_value=employee.status.name if employee.status else "",
+                notes="Employee created from Staff Directory.",
+                recorded_by=_recorded_by(request),
+                start_date=employee.hire_date,
+            )
+        return _ok(
+            {"employee": _employee_data(employee), "temporary_password": temporary_password},
+            status=201,
+        )
+    except ValidationError as exc:
+        return _error("Validation failed.", details=_validation_details(exc))
+    except IntegrityError:
+        return _error("Employee could not be created because a unique value is already in use.")
+
+
+@require_POST
+@_staff_required
+def update_employee(request, employee_id):
+    employee = _employee_or_none(employee_id)
+    if employee is None:
+        return _error("Employee not found.", status=404)
+    try:
+        data = _read_json(request)
+        username = _clean_text(data, "username", required=True)
+        email = _clean_text(data, "email", required=True)
+        validate_email(email)
+        values = _employee_values(data)
+        _validate_unique_user(username, email, employee.user)
+        _validate_employee_id(values["employee_id"], employee)
+
+        with transaction.atomic():
+            user = employee.user
+            if user is None:
+                user = User(
+                    username=username,
+                    email=email,
+                    first_name=values["first_name"],
+                    last_name=values["last_name"],
+                )
+                user.set_unusable_password()
+                user.save()
+                employee.user = user
+            else:
+                user.username = username
+                user.email = email
+                user.first_name = values["first_name"]
+                user.last_name = values["last_name"]
+                user.save()
+            for field, value in values.items():
+                setattr(employee, field, value)
+            employee.save()
+        return _ok({"employee": _employee_data(employee)})
+    except ValidationError as exc:
+        return _error("Validation failed.", details=_validation_details(exc))
+    except IntegrityError:
+        return _error("Employee could not be updated because a unique value is already in use.")
+
+
+@require_POST
+@_staff_required
+def change_employee_status(request, employee_id):
+    employee = _employee_or_none(employee_id)
+    if employee is None:
+        return _error("Employee not found.", status=404)
+    try:
+        data = _read_json(request)
+        action = _clean_text(data, "action", required=True).lower()
+        if action not in {"activate", "terminate"}:
+            raise ValidationError({"action": "Action must be activate or terminate."})
+
+        with transaction.atomic():
+            previous_status = employee.status.name if employee.status else ""
+            if action == "activate":
+                status = _status_named("Active")
+                employee.status = status
+                if employee.user:
+                    employee.user.is_active = True
+                    employee.user.save(update_fields=["is_active"])
+                event_type = "reinstated"
+                notes = "Employee activated from Staff Directory."
+                event_date = timezone.localdate()
+            else:
+                reason = _clean_text(data, "reason", required=True)
+                event_date = _parse_date(data.get("exit_date"), "exit_date", required=True)
+                status = _status_named("Terminated")
+                employee.status = status
+                if employee.user:
+                    employee.user.is_active = False
+                    employee.user.save(update_fields=["is_active"])
+                ExitRecord.objects.create(
+                    employee=employee,
+                    exit_type="Terminated",
+                    exit_date=event_date,
+                    reason=reason,
+                )
+                event_type = "terminated"
+                notes = reason
+
+            employee.save(update_fields=["status"])
+            EmployeeHistory.objects.create(
+                employee=employee,
+                department=employee.department,
+                position=employee.position,
+                event_type=event_type,
+                old_value=previous_status,
+                new_value=employee.status.name,
+                notes=notes,
+                recorded_by=_recorded_by(request),
+                start_date=event_date,
+            )
+        return _ok({"employee": _employee_data(employee)})
+    except ValidationError as exc:
+        return _error("Validation failed.", details=_validation_details(exc))
